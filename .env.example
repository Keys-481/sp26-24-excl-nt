# This is  a template for the .env file.
# Copy this file to .env and fill in the actual values.
# The real .env file should not be committed to version control.

# React app HTML root URL
PUBLIC_URL=

# API Base URL
API_BASE_URL=/api

# Backend server port
PORT=3000

# Database Credentials (PROD)
DB_HOST=your_database_host
DB_USER=your_database_username
DB_PASS=your_database_password
DB_NAME=your_database_name
DB_PORT=5432

# Optional: used in "login info" email sent to new users (login link)
# PUBLIC_URL= (e.g. https://yourapp.example.com or https://yourapp.example.com/s26-excl-nt)
# APP_NAME= (e.g. "Student Degree Planner") – used in email body

# Optional: SMTP for sending login-info emails to new users. If not set, emails are logged only (dev/test).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM= (defaults to SMTP_USER)

# Add other environment variables as needed
