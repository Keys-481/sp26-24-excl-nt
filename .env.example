# Template for the root `.env` file.
#
# Quick start (local dev):
#   cp .env.example .env
#   cp .env.example.dev .env.dev
#   cp .env.example.test .env.test
#   npm run dev
#
# Run tests:
#   npm run test
#
# Notes:
# - Do NOT commit `.env`, `.env.dev`, or `.env.test`.
# - `PUBLIC_URL` / `API_BASE_URL` are PATHS (basename), not full URLs.
# - The frontend (Vite) reads env vars that start with `VITE_` (see below).

# -----------------------------------------------------------------------------
# 1) Basename / paths (SDP deploy + local)
# -----------------------------------------------------------------------------
# Basename/path where the app is hosted.
# SDP example: if your app URL is https://sdp.boisestate.edu/s26-excl-nt/login
# then set PUBLIC_URL=/s26-excl-nt
PUBLIC_URL=/basename

# Where the app is served (no trailing slash). Used only for absolute links in emails.
# Example SDP deploy: PUBLIC_APP_ORIGIN=https://sdp.boisestate.edu
# PUBLIC_APP_ORIGIN=

# Optional: full login URL for emails (overrides PUBLIC_APP_ORIGIN + PUBLIC_URL).
# LOGIN_PAGE_URL=https://sdp.boisestate.edu/basename/login

# API Base URL
API_BASE_URL=/basename/api

# -----------------------------------------------------------------------------
# 2) Backend server
# -----------------------------------------------------------------------------
PORT=3000

# -----------------------------------------------------------------------------
# 3) Database credentials (used by Docker/prod)
# -----------------------------------------------------------------------------
DB_HOST=your_database_host
DB_USER=your_database_username
DB_PASS=your_database_password
DB_NAME=your_database_name
DB_PORT=5432

# -----------------------------------------------------------------------------
# 4) Email links (used in login-instructions emails)
# -----------------------------------------------------------------------------
# Email clients need a FULL URL. Keep PUBLIC_URL as a path, and set the origin here.
# SDP example:
#   PUBLIC_APP_ORIGIN=https://sdp.boisestate.edu
PUBLIC_APP_ORIGIN=
#
# Optional: force the exact login page URL used in emails (overrides PUBLIC_APP_ORIGIN + PUBLIC_URL).
# LOGIN_PAGE_URL=https://sdp.boisestate.edu/basename/login
LOGIN_PAGE_URL=

# -----------------------------------------------------------------------------
# 5) Frontend (Vite) env vars (only VITE_* are exposed to the browser)
# -----------------------------------------------------------------------------
# These should mirror PUBLIC_URL / API_BASE_URL:
VITE_PUBLIC_URL=/basename
VITE_API_BASE_URL=/basename/api
#
# Optional: where the backend is running locally (used by Vite proxy target).
# VITE_API_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# 6) SMTP (optional)
# -----------------------------------------------------------------------------
# SMTP for sending login-info emails to new users.
# If not set, emails are logged only (dev/test).
# If using Gmail, use an App Password (not your normal login password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_SECURE=false
SMTP_USER=your-service-account@u.boisestate.edu
SMTP_PASS=your_app_password_here
SMTP_FROM="SDP Notifications <your-service-account@u.boisestate.edu>"


